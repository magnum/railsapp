<div class="field-unit__label">
  <%= f.label field.attribute %>
</div>
<div class="field-unit__field">
  <%#= f.text_field field.attribute %>
  <% options = field.resource.class.send(field.attribute.to_s.pluralize).keys %>
  <%#= options %>
  <%= f.select field.attribute, 
    options, 
    { include_blank: false, selected: f.object.send(field.attribute) },
    class: "block rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full"
  %>

</div>
