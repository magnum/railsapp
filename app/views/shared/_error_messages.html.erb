<% errors = local_assigns[:errors] || (local_assigns[:object] && local_assigns[:object].errors) %>
<% if errors && errors.any? %>
<div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded">
    <h3 class="text-md font-medium"><%= t('views.errors.fix_errors') %></h3>
    <ul class="mt-2 text-md list-disc list-inside">
    <% errors.full_messages.each do |message| %>
        <li><%= message %></li>
    <% end %>
    </ul>
</div>
<% end %>