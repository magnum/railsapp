<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || Settings.app.name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Railsapp">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50 font-sans">
    <header class="bg-white border-b border-gray-200">
      <nav class="container mx-auto px-4 py-3 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <%= link_to Settings.app.name, root_path, class: "text-2xl font-semibold text-gray-900" %>
        </div>
        <div class="flex items-center gap-4">
          <%= render "shared/locale_select" %>
          <% if signed_in? %>
            <% if current_user.admin? %>
              <%= link_to "Admin", admin_root_path, class: "hidden md:inline text-base font-medium text-gray-700 hover:text-gray-900" %>
              <%= link_to t("users.index.title"), users_path, class: "hidden md:inline text-base font-medium text-gray-700 hover:text-gray-900" %>
            <% end %>
            <%= link_to user_path(current_user), class: "flex items-center gap-2" do %>
              <%= render "users/avatar", user: current_user %>
              <span class="hidden sm:inline text-base text-gray-600"><%= current_user.email %></span>
            <% end %>
            <%= button_to t("sessions.sign_out"), sign_out_path, method: :delete, class: "text-base font-medium text-gray-700 hover:text-gray-900 bg-transparent border-0 p-0 cursor-pointer inline" %>
          <% else %>
            <%= link_to t("sessions.sign_in"), sign_in_path, class: "btn-default" %>
            <%= link_to t("views.invitations.use_invitation_code"), invitation_consume_path, class: "btn-primary" %>
          <% end %>
        </div>
      </nav>
    </header>

    <% if flash.any? %>
      <div class="container mx-auto px-4 py-2">
        <%= render "shared/flashes" %>
      </div>
    <% end %>

    <main class="container mx-auto mt-8 px-5 flex">
      <%= yield %>
    </main>
  </body>
</html>
