<div class="flex justify-center items-center">
  <div class="max-w-lg w-full space-y-8 bg-white p-8 rounded-lg">
    <div class="text-center">
      <h2 class="mt-6 text-3xl font-bold text-gray-900"><%= t("views.invitations.consume_title") %></h2>
      <p class="mt-2 text-md text-gray-600">
        <%= t("views.invitations.consume_intro") %>
      </p>
    </div>

    <%= form_with url: invitation_consume_path, method: :post, local: true, class: "mt-8 space-y-6" do |form| %>
      <div>
        <%= form.label :code, t("views.invitations.invitation_code"), class: "block text-md font-medium text-gray-700" %>
        <%= form.text_field :code,
            value: @code,
            class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-md",
            placeholder: t("views.invitations.invitation_code_placeholder"),
            required: true,
            autofocus: true %>
      </div>

      <div>
        <%= form.submit t("views.invitations.continue_to_sign_up"),
            class: "btn-primary w-full" %>
      </div>
    <% end %>

    <p class="text-center text-sm text-gray-500">
      <%= link_to t("views.invitations.back_to_home"), root_path, class: "font-medium text-blue-600 hover:text-blue-500" %>
    </p>
  </div>
</div>
