
<%#
# Javascript Partial

This partial imports the necessary javascript on each page.
By default, it includes the application JS,
but each page can define additional JS sources
by providing a `content_for(:javascript)` block.
%>


<script src="https://cdnjs.cloudflare.com/ajax/libs/jsoneditor/10.3.0/jsoneditor.min.js" integrity="sha512-TY95hQtaRsYMY6umssOX69V3eIN5lmnW9rEpGSxpyDPzS+E6IAyS9L7QAUboI3hRYuoHB8GAAr7OBxevLdryzA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

<% Administrate::Engine.javascripts.each do |js_path| %>
  <%= javascript_include_tag js_path, "data-turbo-track": "reload", defer: true , type: "module" %>
<% end %>

<%= render "/shared/google_analytics" %>

<%= yield :javascript %>

<% if Rails.env.test? %>
  <%= javascript_tag do %>
    $.fx.off = true;
    $.ajaxSetup({ async: false });
  <% end %>
<% end %>
