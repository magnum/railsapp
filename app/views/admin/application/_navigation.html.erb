<%#
# Navigation

This partial is used to display the navigation in Administrate.
By default, the navigation contains navigation links
for all resources in the admin dashboard,
as defined by the routes in the `admin/` namespace
%>

<nav class="navigation">
  <%= link_to Settings.app.name, root_path, class: "app-name mt-4 text-3xl font-bold tracking-tighterfont-bold mb-4 block" %>
  <%#= content_tag :div, Settings.app.name, class: "text-3xl font-bold mb-4" %>
  <%#= link_to(t("administrate.navigation.back_to_app"), root_url, class: "button button--alt button--nav") if defined?(root_url) %>

  <% Administrate::Namespace.new(namespace).resources_with_index_route.each do |resource| %>
    <%= link_to(
      display_resource_name(resource),
      resource_index_route(resource),
      class: "navigation__link navigation__link--#{nav_link_state(resource)}"
    ) if accessible_action?(model_from_resource(resource), :index) %>
  <% end %>

  <%= link_to "Jobs", "/jobs", class: "navigation__link navigation__link--inactive", target: "_blank" if current_user.admin? %>

  <div class="locale flex flex-row gap-2 mt-4 mb-4">
    <% I18n.available_locales.each do |locale| %>
      <%= link_to locale.upcase, 
        set_session_locale_path(locale: locale), 
        class: "hover:text-blue-700 hover:underline #{I18n.locale == locale ? 'font-bold' : ''}", 
        data: { turbo_prefetch: false,turbo: false }
      %>
    <% end %>
  </div>

  <%= link_to "Logout", sign_out_path, class: "navigation__link--inactive pb-4 block", data: { turbo_method: :delete} %>

  <%#= render "/shared/sentry_session_replay" %>
</nav>
