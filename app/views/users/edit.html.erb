<div class="w-full max-w-2xl">
  <div class="bg-white shadow-sm rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h1 class="text-2xl font-bold text-gray-900"><%= t("users.edit.title") %></h1>
      <%= link_to t("users.actions.show"), @user, class: "btn-default" %>
    </div>

    <div class="px-6 py-4">
      <%= form_with model: @user, url: user_path(@user), method: :patch, local: true, class: "space-y-4" do |f| %>
        <%= render "shared/error_messages", object: @user %>

        <div>
          <%= f.label :firstname, t("activerecord.attributes.user.firstname"), class: "block text-base font-medium text-gray-700 mb-1" %>
          <%= f.text_field :firstname, class: "block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
        </div>

        <div>
          <%= f.label :lastname, t("activerecord.attributes.user.lastname"), class: "block text-base font-medium text-gray-700 mb-1" %>
          <%= f.text_field :lastname, class: "block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
        </div>

        <div>
          <%= f.label :email, t("activerecord.attributes.user.email"), class: "block text-base font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, class: "block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
        </div>

        <div class="flex gap-2">
          <%= f.submit t("users.edit.submit"), class: "btn-primary" %>
          <%= link_to t("common.cancel"), @user, class: "btn-default" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
